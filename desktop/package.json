{
  "name": "agenttrace-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "AgentTrace for Mac — see what your AI coding agents did, in a native window.",
  "author": "AgentTrace contributors",
  "main": "main.js",
  "scripts": {
    "build": "node scripts/build.mjs",
    "start": "npm run build && electron .",
    "dist": "npm run build && electron-builder --mac",
    "dist:dir": "npm run build && electron-builder --mac --dir"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.0"
  },
  "build": {
    "appId": "app.raiselabs.agenttrace",
    "productName": "AgentTrace",
    "afterSign": "scripts/notarize.cjs",
    "afterAllArtifactBuild": "scripts/staple-dmg.cjs",
    "files": [
      "main.js",
      "core.cjs",
      "assets/**"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] }
      ],
      "icon": "assets/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "dmg": {
      "title": "AgentTrace ${version}"
    },
    "directories": {
      "output": "release"
    }
  }
}

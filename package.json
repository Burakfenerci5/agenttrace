{
  "name": "agenttrace-cli",
  "version": "0.1.0",
  "description": "See what your AI coding agents actually accomplished — every Claude Code session mapped to the files it changed, the commits it produced, and whether they stuck. Local-first, zero backend.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "claude-code",
    "ai-agents",
    "observability",
    "developer-tools",
    "cli",
    "local-first"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Burakfenerci5/agenttrace.git"
  },
  "homepage": "https://github.com/Burakfenerci5/agenttrace#readme",
  "bin": {
    "agenttrace": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": { "node": ">=20" },
  "scripts": {
    "dev": "node src/cli.ts",
    "start": "node src/cli.ts",
    "build": "node scripts/build.mjs",
    "metrics": "node scripts/metrics.mjs",
    "test": "node --test \"test/**/*.test.ts\"",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0"
  }
}
